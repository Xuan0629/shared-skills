 def inline_references(body: str, skill_name: str) -> str:
     """将 references/ 内容内联到正文末尾。"""
     refs = list_references(skill_name)
     if not refs:
         return body
     parts = [body, "", "## References (inlined)"]
     for ref in refs:
         parts.append(f"\n### {ref.name}")
         parts.append(ref.read_text().strip())
     return "\n".join(parts)
 
 
