    82	def parse_frontmatter(filepath: Path) -> dict | None:
    83	    """Parse YAML frontmatter from a SKILL.md file.
    84	
    85	    Returns the parsed dict on success, None if the file is missing,
    86	    has no frontmatter, or the YAML is invalid.
    87	    """
    88	    if not filepath.exists():
    89	        return None
    90	    content = filepath.read_text()
    91	    if not content.startswith("---"):
    92	        return None
    93	    end = content.find("---", 3)
    94	    if end == -1:
    95	        return None
    96	    fm_text = content[3:end].strip()
    97	    if not fm_text:
    98	        return None
    99	    try:
   100	        parsed = yaml.safe_load(fm_text)
   101	        return parsed if isinstance(parsed, dict) else None
   102	    except yaml.YAMLError:
   103	        return None
   104	
   105	
   106	def build_hermes_frontmatter(skill_name: str, meta: dict, source_hash: str = "") -> str:
   107	    """生成 Hermes 格式的 YAML frontmatter（含 triggers）。"""
   108	    triggers = meta.get("hermes", {}).get("triggers", [])
   109	    description = meta.get("claude", {}).get("description", skill_name)
   110	    lines = ["---", f"name: {skill_name}", f"description: {description}"]
   111	    if triggers:
   112	        lines.append("triggers:")
   113	        for t in triggers:
   114	            # regex patterns with special chars need quoting
   115	            if any(c in t for c in ".*{}[]()"):
   116	                lines.append(f'  - "{t}"')
   117	            else:
   118	                lines.append(f"  - {t}")
   119	    if source_hash:
   120	        lines.append(f"source_hash: {source_hash}")
   121	    lines.append("---")
   122	    return "\n".join(lines)
   123	
