   262	def check_skills(verbose: bool = False, targets: list[str] | None = None):
   263	    """Scan agent skill copies and compare stored source_hash against current source.
   264	
   265	    For each skill in the manifest and each configured agent, reports:
   266	    - UP-TO-DATE: stored hash matches current source
   267	    - OUTDATED: stored hash differs from current source (agent copy is stale)
   268	    - MISSING: no agent copy found, or no source_hash in its frontmatter
   269	
   270	    If targets is provided, only check skills whose names are in the list.
   271	    """
   272	    manifest = load_manifest()
   273	
   274	    # Agent display order
   275	    agent_names = list(AGENT_CONFIGS.keys())
   276	
   277	    for skill_name, meta in manifest.items():
   278	        if targets and skill_name not in targets:
   279	            continue
   280	        current_hash = compute_source_hash(skill_name, meta)
   281	        print(f"{skill_name}:")
   282	        for agent in agent_names:
   283	            path = get_agent_skill_path(agent, skill_name, meta)
   284	            if path is None:
   285	                continue
   286	            fm = parse_frontmatter(path)
   287	            if fm is None:
   288	                print(f"  {agent}: MISSING")
   289	                continue
   290	            stored_hash = fm.get("source_hash")
   291	            if not stored_hash:
   292	                print(f"  {agent}: MISSING")
   293	            elif stored_hash == current_hash:
   294	                if verbose:
   295	                    print(f"  {agent}: UP-TO-DATE ({current_hash[:12]})")
   296	                else:
   297	                    print(f"  {agent}: UP-TO-DATE")
   298	            else:
   299	                short_current = current_hash[:12]
   300	                short_stored = stored_hash[:12] if len(stored_hash) >= 12 else stored_hash
   301	                if verbose:
   302	                    print(f"  {agent}: OUTDATED ({short_stored} vs {short_current})")
   303	                else:
   304	                    print(f"  {agent}: OUTDATED ({short_stored} vs {short_current})")
