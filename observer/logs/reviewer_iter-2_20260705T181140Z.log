    67	def compute_source_hash(skill_name: str, meta: dict) -> str:
    68	    """Compute SHA256 hash of raw SKILL.md + serialized manifest metadata.
    69	
    70	    This hash captures the full shared source for a skill — both its body
    71	    and its agent-specific metadata (triggers, categories, descriptions).
    72	    Any change to either will produce a different hash, which --check uses
    73	    to detect outdated agent copies.
    74	    """
    75	    skill_path = SHARED / skill_name / "SKILL.md"
    76	    skill_bytes = skill_path.read_bytes()
    77	    meta_bytes = yaml.dump(meta, sort_keys=True, allow_unicode=True).encode("utf-8")
    78	    combined = skill_bytes + b"\n---META---\n" + meta_bytes
    79	    return hashlib.sha256(combined).hexdigest()
    80	
