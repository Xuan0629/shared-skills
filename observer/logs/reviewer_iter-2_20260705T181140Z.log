   249	def get_agent_skill_path(agent: str, skill_name: str, meta: dict) -> Path | None:
   250	    """Return the Path to an agent's copy of a skill, or None if the agent
   251	    has no config for this skill type."""
   252	    config = AGENT_CONFIGS.get(agent)
   253	    if not config:
   254	        return None
   255	    base = config["base"]
   256	    if agent == "hermes":
   257	        category = meta.get("hermes", {}).get("category", "shared")
   258	        return base / category / skill_name / "SKILL.md"
   259	    return base / skill_name / "SKILL.md"
